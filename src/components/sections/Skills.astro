---
import { skillsConfig } from '@/config/site';
---

<section id="skills">
  <div class="container">
    <p class="section-label">05 — Skills</p>
    <h2 class="section-title">Technical Skills</h2>

    <div class="tiers">
      {skillsConfig.map((tier) => (
        <div class="tier-block fade-in">
          <div class="tier-header">
            <span class={`tier-badge tier-badge--${tier.tier.toLowerCase()}`}>
              {tier.tier}
            </span>
            <span class="tier-desc">{tier.description}</span>
          </div>
          <div class="tier-pills">
            {tier.skills.map((s) => (
              <span class={`tag tier-tag tier-tag--${tier.tier.toLowerCase()}`}>
                {s}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .tiers {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tier-block {
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }

  .tier-block:last-of-type {
    border-bottom: none;
  }

  .tier-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .tier-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .tier-badge--core {
    background: rgba(232, 168, 56, 0.15);
    color: var(--accent);
  }

  .tier-badge--proficient {
    background: rgba(97, 175, 239, 0.12);
    color: #61afef;
  }

  .tier-badge--familiar {
    background: rgba(136, 136, 136, 0.12);
    color: var(--text-secondary);
  }

  .tier-badge--learning {
    background: rgba(152, 195, 121, 0.12);
    color: #98c379;
  }

  .tier-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .tier-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tier-tag--core {
    background: rgba(232, 168, 56, 0.1);
    color: var(--accent);
  }

  .tier-tag--proficient {
    background: rgba(97, 175, 239, 0.08);
    color: #61afef;
  }

  .tier-tag--familiar {
    background: rgba(136, 136, 136, 0.08);
    color: var(--text-secondary);
  }

  .tier-tag--learning {
    background: rgba(152, 195, 121, 0.08);
    color: #98c379;
  }

</style>
