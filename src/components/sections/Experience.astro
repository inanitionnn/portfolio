---
import { experienceConfig } from '@/config/site';
---

<section id="experience">
  <div class="container">
    <p class="section-label">02 — Experience</p>
    <h2 class="section-title">Work Experience</h2>

    <div class="timeline">
      {experienceConfig.map((entry) => (
        <div class="timeline-entry fade-in">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <div class="entry-header">
              <div>
                <h3 class="entry-company">
                  <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer">
                    {entry.company}
                  </a>
                </h3>
                <span class="entry-role">{entry.role}</span>
              </div>
              <span class="entry-period">{entry.period}</span>
            </div>
            <ul class="entry-bullets">
              {entry.bullets.map((b) => <li>{b}</li>)}
            </ul>
            <div class="entry-tags">
              {entry.tags.map((t) => <span class="tag">{t}</span>)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    padding-left: 28px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }

  .timeline-entry {
    position: relative;
    margin-bottom: 56px;
  }

  .timeline-entry:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -28px;
    top: 6px;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    border: 2px solid var(--accent);
    background: var(--bg);
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .entry-company a {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    transition: color 0.15s;
  }

  .entry-company a:hover {
    color: var(--accent);
  }

  .entry-role {
    font-size: 0.875rem;
    color: var(--text-secondary);
    display: block;
    margin-top: 2px;
  }

  .entry-period {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .entry-bullets {
    margin-bottom: 16px;
  }

  .entry-bullets li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 16px;
    position: relative;
    margin-bottom: 6px;
  }

  .entry-bullets li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  .entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  @media (max-width: 640px) {
    .entry-header {
      flex-direction: column;
      gap: 4px;
    }

    .entry-period {
      white-space: normal;
    }
  }
</style>
