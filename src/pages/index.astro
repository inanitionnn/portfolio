---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config/site';
---

<BaseLayout
  title={`${siteConfig.name} — ${siteConfig.title}`}
  description={siteConfig.bio}
>
  <section id="hero">
    <div class="container">
      <h1>Hero</h1>
    </div>
  </section>

  <section id="about">
    <div class="container">
      <h2>About</h2>
    </div>
  </section>

  <section id="experience">
    <div class="container">
      <h2>Experience</h2>
    </div>
  </section>

  <section id="projects">
    <div class="container">
      <h2>Projects</h2>
    </div>
  </section>

  <section id="skills">
    <div class="container">
      <h2>Skills</h2>
    </div>
  </section>

  <section id="contact">
    <div class="container">
      <h2>Contact</h2>
    </div>
  </section>
</BaseLayout>
